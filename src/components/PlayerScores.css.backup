.player-scores { 
  background:rgba(255,255,255,0.08); 
  backdrop-filter:blur(20px) saturate(180%); 
  border:1px solid rgba(255,255,255,0.25); 
  border-radius:16px; 
  padding:10px 12px; 
  margin:0 0 8px 0; 
  position: relative;
  overflow: hidden;
  box-shadow: var(--shadow-medium);
}

.player-scores::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: var(--aurora-gradient);
  border-radius: 16px 16px 0 0;
}

.player-scores::after {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255,215,0,0.03) 0%, transparent 70%);
  animation: scoreGlow 4s ease-in-out infinite alternate;
}

@keyframes scoreGlow {
  0% { opacity: 0.5; transform: rotate(0deg); }
  100% { opacity: 1; transform: rotate(180deg); }
}

.player-scores h3 { display:flex; align-items:center; gap:4px; margin:0 0 4px 0; font-size:12px; font-weight:700; background:linear-gradient(135deg,#ffffff 0%,#ffd700 100%); -webkit-background-clip:text; background-clip:text; color:transparent; text-align:center; letter-spacing:1px; }

.player-scores .scores-list { 
  display:flex; 
  flex-direction:column; 
  gap:3px; 
  background: transparent !important; 
  padding: 0 !important; 
  border-radius: 0 !important; 
}

.player-scores .score-item { 
  display:flex; 
  align-items:center; 
  justify-content:space-between; 
  padding:6px 10px; 
  background:rgba(255,255,255,0.1) !important; 
  border-radius:8px; 
  transition:all 0.4s cubic-bezier(0.4, 0, 0.2, 1); 
  margin-bottom: 0 !important; 
  box-shadow: none !important; 
  border: 1px solid rgba(255,255,255,0.1);
  position: relative;
  z-index: 1;
}

.player-scores .score-item:hover {
  transform: translateX(4px);
  background: rgba(255,255,255,0.15) !important;
  box-shadow: var(--shadow-soft) !important;
}

.player-scores .score-item.leader {
  background: rgba(255, 215, 0, 0.25) !important;
  border: 1px solid rgba(255, 215, 0, 0.5);
  box-shadow: 0 0 20px rgba(255,215,0,0.2) !important;
  animation: leaderPulse 2s ease-in-out infinite alternate;
}

@keyframes leaderPulse {
  0% { 
    box-shadow: 0 0 20px rgba(255,215,0,0.2) !important;
    border-color: rgba(255, 215, 0, 0.5);
  }
  100% { 
    box-shadow: 0 0 30px rgba(255,215,0,0.4) !important;
    border-color: rgba(255, 215, 0, 0.8);
  }
}

.player-info {
  display: flex;
  align-items: center;
  gap: 8px;
}

.player-avatar {
  font-size: 16px;
}

.player-scores .player-name { color:white !important; font-weight:600; font-size:11px; }

.player-scores .score-item.leader .player-name {
  color: #ffd700 !important;
}

div.player-scores div.score-item div.player-score,
div.player-scores .score-item .player-score,
.player-scores .score-item .player-score,
.player-scores .player-score { 
  font-weight:700 !important; 
  font-size:12px !important; 
  color:#ffd700 !important; 
  min-width:30px; 
  text-align:right; 
}

.player-scores .score-item.leader .player-score {
  text-shadow: 0 0 10px rgba(255, 215, 0, 0.5);
  color:#ffd700 !important;
  font-weight:700 !important;
}

@media (max-width: 640px) {
  .player-scores { padding:6px 8px; }
  .player-scores .score-item { padding:4px 6px; }
  .player-scores .player-name { font-size:10px !important; color:white !important; }
  .player-scores .player-score { font-size:11px !important; color:#ffd700 !important; }
}

@media (max-width: 520px) {
  .player-scores { padding:5px 6px; }
  .player-scores .score-item { padding:3px 5px; }
  .player-scores .player-name { font-size:9px !important; color:white !important; }
  .player-scores .player-score { font-size:10px !important; color:#ffd700 !important; }
}